# .env.example
# -------------
# This is a TEMPLATE showing which environment variables the app needs.
# Copy it to a file called ".env" and fill in your own values:
#
#     cp .env.example .env
#
# The real ".env" file is git-ignored so secrets never get committed.
# docker-compose automatically reads ".env" in this folder.

# Database credentials (used by both the db and backend services)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=inventory

# Which website origins are allowed to call the backend (comma-separated).
# In local Docker the frontend is at http://localhost:3000.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
